{% macro menuHaut(settings, trad, selecteur, miniCalentrier, selectionDateDirecte, legende, area, room) %}
    <div id ="menuHaut" class="row">

        <!-- Sites, domaine et ressources -->
        <div id ="resource_selectorH" class="col-lg-2 col-md-3 col-xs-12">
            {{selecteur|raw}}
        </div>

        <!-- Sélection date directe -->
        {% if settings.select_date_directe == "y" %}
            <form method="GET" action="app.php" style="text-align: left;">
                <input type="hidden" name="p" value="jour">
                <input type='hidden' name='area' value='{{area}}'>
                <input type='hidden' name='room' value='{{room}}'>
                {{selectionDateDirecte|raw}}
                <button class="btn btn-default btn-sm" type="submit">
                    <i class="fa-solid fa-angles-right"></i>
                </button>
            </form>
        {% endif %}

        <!-- Mini calendrier(s) -->
        <div id ="calendriersH" class="col-lg-8 col-md-6 col-xs-12">
            {{miniCalentrier|raw}}
        </div>

        <!-- Légende -->
            {% if settings.legend == 0 %}
                <div id ="legendeH" class="col-lg-2 col-md-3 col-xs-12">
                    <table class="legende">
                        <caption>{{trad.show_color_key}}</caption>
                        {{legende|raw}}
                    </table>
                </div>
            {% endif %}
    </div>
{% endmacro %}

{% macro menuGauche(settings, trad, selecteur, miniCalentrier, selectionDateDirecte, legende, area, room) %}
    <div id ="menuGauche2">

        <!-- Sélection date directe -->
        {% if settings.select_date_directe == "y" %}
            <form method="GET" action="app.php">
                <input type="hidden" name="p" value="jour">
                <input type='hidden' name='area' value='{{area}}'>
                <input type='hidden' name='room' value='{{room}}'>
                <center>
                    {{selectionDateDirecte|raw}}
                    <button class="btn btn-default btn-sm" type="submit">
                        <i class="fa-solid fa-angles-right"></i>
                    </button>
                </center>
            </form>
        {% endif %}

        <!-- Mini calendrier(s) -->
        <div id ="calendriersG">
            {{miniCalentrier|raw}}
        </div>

        <div class="col-lg-12 col-md-12 col-xs-12">
            <!-- Sites, domaine et ressources -->
            <div id="resource_selectorG">
                {{selecteur|raw}}
            </div>

            <!-- Légende -->
            {% if settings.legend == 0 %}
                <div id ="legendeG">
                    <table class="legende">
                        <caption>{{trad.show_color_key}}</caption>
                        {{legende|raw}}
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endmacro %}

{% macro imprimante(settings, paramUrl) %}
    <button type="button" class="btn btn-default btn-xs" 
    {% if settings.pview_new_windows == 1 %}
        onclick="javascript:window.open('app.php?{% if paramUrl %}{{paramUrl}}&amp;{% endif %}pview=1')">
    {% else %}
        onclick="javascript:location.href='app.php?{% if paramUrl %}{{paramUrl}}&amp;{% endif %}pview=1&amp;precedent=1'">
    {% endif %}
        <i class="fa-solid fa-print"></i>
    </button>
{% endmacro %}

{% macro boutonRetourHaut() %}
    <script type="text/javascript">
        $(function(){
            $(window).scroll(function(){
                if ($(window).scrollTop() != 0)
                    $("#toTop").fadeIn();
                else
                    $("#toTop").fadeOut();
            });
            $("#toTop").click(function(){
                $("body,html").animate({scrollTop:0},800);
            });
        });
    </script>
{% endmacro %}

{% macro popupMsg(settings, message, affiche) %}

    {% if message %}
        {% if settings.javascript_info_disabled == 0 and affiche == 1 %}
            <script type="text/javascript">
                alert("{{message}}");
            </script>
        {% endif %}
    {% endif %}

{% endmacro %}

{% macro erreurMailAuto(settings, trad, sessionMessageErreur) %}

    {% if settings.javascript_info_disabled == 0 and sessionMessageErreur %}
        <script type="text/javascript">
            alert("{{trad.title_automatic_mail}}\n{{sessionMessageErreur}}\n{{trad.technical_contact}}");
        </script>
    {% endif %}

{% endmacro %}

{% macro dragAndDrop(settings, trad, d) %}
	{% if settings.fct_drag_drop == 'y' and d.levelUser >= 2 %} <!-- Si le drag&drop est activé et que l'utilisateur est au minimum USAGER -->
        <script type="text/javascript">
		$(function(){
			// Réinitialiser le Drag&Drop dans un bloc propre (l'original peut contenir une erreur de syntaxe)
			$(".resadrag").draggable({helper:"clone",revert:"invalid",
				start:function(event,ui){ $(this).css('opacity',0.5); ui.helper.css('width', $(this).width()); },
				stop:function(){ $(this).css('opacity',1); }
			});
			$(".dragdrop").droppable({accept:".resadrag",tolerance:"pointer",
				drop:function(event,ui){
					var id      = ui.draggable.data('resa-id');
					var target  = $(event.target).closest('.dragdrop');
                    var hour    = target.data('hour') ?? -1;
					var minute  = target.data('minute') ?? -1;
                    var day     = target.data('day');
					var month   = target.data('month');
					var year    = target.data('year');
					var ressource = target.data('ressource');
				    //console.log('drop debug: ', id, day, month, year, ressource,hour,minute);
					if(id && day && month && year){
						bougerResa(id,day,month,year,ressource,hour,minute);
					}
				}
			});

			function bougerResa(id,day,month,year,ressource,hour,minute){
				$.ajax({
					url: 'app.php?p=dragdrop',
					data: {id:id,day:day,month:month,year:year,ressource:ressource,hour:hour,minute:minute},
					success: function(res){
						var msg = $.trim(res);
						if(msg == 'ok'){
							location.reload();
						} else if (msg == 'conflit'){
							alert('{{trad.reservation_impossible}} '+day+'/'+month+'/'+year);
						} else {
							alert(msg);
						}
					}
				});
			}
		});
        </script>
	{% endif %}
{% endmacro %}
		<form enctype="multipart/form-data" action="?p=admin_page_reservation" method="post" class="col col-12">
			<input type="hidden" name="p" value="admin_page_reservation" />
			<input type="hidden" name="submit" value="1" />

        	<div class="col col-12">

				<!-- Accès & droits -->

										<span class="input-group-text"><i class="far fa-calendar-alt"></i></span>
									</div>
									<input type="text" class="form-control pull-right" id="plageresa" name="plageresa" value="{{ d.begin_bookings }} - {{ d.end_bookings }}">
								</div>
							</div>
							<i>{{ trad.begin_bookings_explain }}</i>

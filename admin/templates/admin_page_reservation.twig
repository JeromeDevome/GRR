{% block javascript %}
	<script src="../jslib/moment/moment.min.js"></script>
	<script src="../jslib/daterangepicker/daterangepicker.js"></script>
	<script type="text/javascript">

		// Gestion affichage/masquage holidays_zone selon show_holidays
		$(function() {
			function toggleHolidaysZone() {
				const showHolidays = $('input[name="show_holidays"]:checked').val();
				if (showHolidays == 1) {
					$('#div_holidays_zone').show();
				} else {
					$('#div_holidays_zone').hide();
				}
			}

			// A chaque changement
			$('input[name="show_holidays"]').on('change', toggleHolidaysZone);
		});

		function modifier_liste_domaines(){
			$.ajax({
				url: "../compte/my_account_modif_listes.php",
				type: "get",
				dataType: "html",
				data: {
					id_site: $('#id_site').val(),
					default_area : '{{ settings.default_area }}',
					session_login:'{{ d.nomUtilisateur }}',
					use_site:'{{ settings.module_multisite }}',
					type:'domaine',
				},
				success: function(returnData){
					console.log(returnData);
					$("#div_liste_domaines").html(returnData);
				},
				error: function(e){
					alert(e);
				}
			});
		}
		function modifier_liste_ressources(action){
			$.ajax({
				url: "../compte/my_account_modif_listes.php",
				type: "get",
				dataType: "html",
				data: {
					id_area:$('id_area').serialize(true),
					default_room : '{{ settings.default_room }}',
					type:'ressource',
					action:+action,
				},
				success: function(returnData){
					$("#div_liste_ressources").html(returnData);
				},
				error: function(e){
					alert(e);
				}
			});
		}
		modifier_liste_domaines();
		modifier_liste_ressources(1);

		// Modal
		$('#modal-warning').on('show.bs.modal', function (event) {
			var button = $(event.relatedTarget) // Button that triggered the modal
			var idsynchro = button.data('idsynchro')// Extract info from data-* attributes
			var texte = button.data('texte')
		    // If necessary, you could initiate an AJAX request here (and then do the updating in a callback).
		    // Update the modal's content. We'll use jQuery here, but you could use a data binding library or other methods instead.
		    var modal = $(this)
		    modal.find('.modalidsync').text(idsynchro)
			modal.find('.modaltexte').text(texte)
		})

		$(function(){
			$('#formmodal').submit(function(e) {
			  e.preventDefault()
			  var $form = $(this)
			  var v=document.getElementById('modalidsync').innerHTML
			  $.post($form.attr('action'), $form.serialize())
			  .done(function(data) {
				$('#html').html(data);
				$('#modal-warning').modal('hide');
				document.location.href='?p=admin_config6&sync='+v;
			  })
			  .fail(function() {
				alert('Une erreur est survenue : GRRJS')
			  })
			})

			// Plage de réservation
			$('#plageresa').daterangepicker({
				"locale": {
					"format": "DD/MM/YYYY",
					"separator": " - ",
					"applyLabel": "Valider",
					"cancelLabel": "Annuler",
					"fromLabel": "De",
					"toLabel": "à",
					"customRangeLabel": "Custom",
					"daysOfWeek": [
						"Dim",
						"Lun",
						"Mar",
						"Mer",
						"Jeu",
						"Ven",
						"Sam"
					],
					"monthNames": [
						"Janvier",
						"Février",
						"Mars",
						"Avril",
						"Mai",
						"Juin",
						"Juillet",
						"Août",
						"Septembre",
						"Octobre",
						"Novembre",
						"Décembre"
					],
					"firstDay": 1
				}
			});

			{%if d.enregistrement%}
				{%if d.enregistrement == 1 %}
					toastr.success("{{trad.message_records}}")
				{% else %}
					toastr.warning("{{d.enregistrement|raw}}")
				{%endif%}
			{%endif%}

			// Afficher/masquer la section de contact réservation
			var $radioFormContactResa = $('input[name="mail_etat_destinataire"]');
			var $sectionContactResa = $('#aff_dyn_form_contact_resa');

			// À la modification des radio buttons
			$radioFormContactResa.on('change', function() {
				var selectedValue = $('input[name="mail_etat_destinataire"]:checked').val();
				if (selectedValue == 0) {
					$sectionContactResa.slideUp();
				} else {
					$sectionContactResa.slideDown();
				}
			});
		})

	</script>

{% endblock %}

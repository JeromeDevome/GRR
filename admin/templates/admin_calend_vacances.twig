{% extends 'layout.twig' %}

{% import 'messagesysteme.twig' as msgSyst %}
{% import 'champs.twig' as form %}

{% block css %}{% endblock %}

{% block content %}
	<div class="row">
		<div class="col col-md-12">

			{% if trad.dNettoyageLiaison  %}
				{{ msgSyst.messageInfo('Résultat', trad.dNettoyageLiaison) }}
			{% endif %}


			<div class="box">
				<div class="box-header">
					<h3 class="box-title">{{ trad.admin_calend_vacances_feries }}</h3>
				</div>
				<!-- /.box-header -->
				<div class="box-body no-padding">
					<p>{{ trad.vacances_feries_description }}</p>

					{% if settings.show_holidays != 1 %}
						<p>Il faut activer l'affichage des vacances pour continuer...</p>
						<p><a href="?p=admin_page_reservation" >Cliquer ici pour activer l'affichage des vacances</a>
					{% else %}
						<div class="form-group row">
							<form action="?p=admin_calend_vacances" method="POST" id="annee">
								<input type="hidden" name="p" value="admin_calend_vacances" />
								{{d.liste_annees |raw }}
								<input class="btn btn-primary" type="submit" name="{{ trad.OK }}" value="{{ trad.OK }}" />&nbsp;
							</form>	
							{% if settings.holidays_zone != 0 %}
								<a href="?p=admin_calend_vacances" class="btn btn-xs btn-info" onclick="{{ d.cocheVacances }} return false;">{{ trad.vacances_FR }} {{ settings.holidays_zone }}</a> &nbsp;
							{% endif %}
							<a href="?p=admin_calend_vacances" class="btn btn-xs btn-info" onclick="setCheckboxesGrr(document.getElementById('formulaireV'), false, 'all'); return false;">{{ trad.uncheck_all_ }}</a>&nbsp;
						</div>

						<form action="?p=admin_calend_vacances" method="post" id="formulaireV">
							<input type="hidden" name="p" value="admin_calend_vacances" />
							<input type="hidden" name="submitCalend" value="1" />
							<input type="hidden" name="From_year" value="{{ d.From_year }}" />
							<div class="row">
								{{ d.calendrier |raw }}
							</div>
							<!-- Enregistrer -->
							<button type="submit" name="ok" class="btn btn-primary position-fixed elevation-4" style="bottom:70px; right:20px; z-index:99;">
								<i class="fas fa-save"></i> {{ trad.save }}
							</button>
						</form>
					{% endif %}
				</div>
			</div>
		</div>
	</div>

{% endblock %}

{% block javascript %}
<script>
	function setCheckboxesGrrName(elts, do_check, day)
	{
		for (i = 0; i < elts.length; i++)
		{
			type = elts.type;
			if (type="checkbox")
			{
				if (elts[i].name== day)
				{
					elts[i].checked = do_check;
				}
			}
		}
		return true;
	}

	function setCheckboxesGrr(elts, do_check, day)
	{
		for (i = 0; i < elts.length; i++)
		{
			type = elts.type;
			if (type="checkbox")
			{
				if ((elts[i].value== day) || (day=='all'))
				{
					elts[i].checked = do_check;
				}
			}
		}
		return true;
	}
</script>
{% endblock %}
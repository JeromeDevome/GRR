                        <p>{{trad.mail_desc_dest_adm}}</p>
                        {{ form.input(titreform1, "", pages[namform1][0], {classGroup: 'col-sm-12', classLabel: 'col-sm-0', classInput: 'col-sm-12 control-label'}) }}
                        {{ form.summernote(namform1, '', pages[namform1][1], {classGroup: 'col-sm-12', classInput: 'col-sm-12', name: namform1}) }}

                        <p>{{trad.mail_desc_dest_beneficiaire}}</p>
                        {{ form.input(titreform2, "", pages[namform2][0], {classGroup: 'col-sm-12', classLabel: 'col-sm-0', classInput: 'col-sm-12 control-label'}) }}
                        {{ form.summernote(namform2, '', pages[namform2][1], {classGroup: 'col-sm-12', classInput: 'col-sm-12', name: namform2}) }}

                        <p>{{trad.mail_desc_dest_gestionnaire}}</p>
                        {{ form.input(titreform3, "", pages[namform3][0], {classGroup: 'col-sm-12', classLabel: 'col-sm-0', classInput: 'col-sm-12 control-label'}) }}
                        {{ form.summernote(namform3, '', pages[namform3][1], {classGroup: 'col-sm-12', classInput: 'col-sm-12', name: namform3}) }}
                      </div>

                      <!-- Mail Décision modération -->
                      <div class="tab-pane fade" id="vert-tabs-{{langue}}-resamoderationdecision" role="tabpanel" aria-labelledby="vert-tabs-{{langue}}-resamoderationdecision-tab">
                        <h3>{{trad.mail_type_resa_moderation_decision}}</h3>
                        {% set titreform1 = 'mails_resa_6_1_titre_'~ langue %}
                        {% set titreform2 = 'mails_resa_6_2_titre_'~ langue %}
                        {% set namform1 = 'mails_resa_6_1_'~ langue %}
                        {% set namform2 = 'mails_resa_6_2_'~ langue %}
                        
                        <p>{{trad.mail_desc_dest_adm}}</p>
                        {{ form.input(titreform1, "", pages[namform1][0], {classGroup: 'col-sm-12', classLabel: 'col-sm-0', classInput: 'col-sm-12 control-label'}) }}
                        {{ form.summernote(namform1, '', pages[namform1][1], {classGroup: 'col-sm-12', classInput: 'col-sm-12', name: namform1}) }}

                        <p>{{trad.mail_desc_dest_beneficiaire}}</p>
                        {{ form.input(titreform2, "", pages[namform2][0], {classGroup: 'col-sm-12', classLabel: 'col-sm-0', classInput: 'col-sm-12 control-label'}) }}
                        {{ form.summernote(namform2, '', pages[namform2][1], {classGroup: 'col-sm-12', classInput: 'col-sm-12', name: namform2}) }}

                      <!-- Mail Retard restitution -->
                      <div class="tab-pane fade" id="vert-tabs-{{langue}}-retardrestitution" role="tabpanel" aria-labelledby="vert-tabs-{{langue}}-retardrestitution-tab">
                        <h3>{{trad.mail_type_resa_retard}}</h3>
                        {% set titreform1 = 'mails_resa_7_1_titre_'~ langue %}
                        {% set titreform2 = 'mails_resa_7_2_titre_'~ langue %}
                        {% set namform1 = 'mails_resa_7_1_'~ langue %}

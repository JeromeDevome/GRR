                        <h3>{{trad.mail_type_compte_demande}}</h3>
                        {% set titreform = 'mails_demandecompte_titre_'~ langue %}
                        {% set titreform2 = 'mails_demandecompte2_titre_'~ langue %}
                        {% set titreform3 = 'mails_demandecompte3_titre_'~ langue %}
                        {% set namform = 'mails_demandecompte_'~ langue %}
                        {% set namform2 = 'mails_demandecompte2_'~ langue %}
                        {% set namform3 = 'mails_demandecompte3_'~ langue %}

                        <p>{{trad.mail_desc_compte_creation}}</p>
                        {{ form.input(titreform, "", pages[namform][0], {classGroup: 'col-sm-12', classLabel: 'col-sm-0', classInput: 'col-sm-12 control-label'}) }}
